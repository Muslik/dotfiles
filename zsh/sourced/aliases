#########################################
# Quick dotfiles                        #
#########################################
alias zshconfig="nvim ~/dotfiles/zsh/zshrc"
alias zshaliases="nvim ~/dotfiles/zsh/sourced/aliases"
alias zshfunctions="nvim ~/dotfiles/zsh/sourced/functions"
alias vimconfig="nvim ~/dotfiles/vim/vimrc"
alias nvimconfig="nvim ~/dotfiles/nvim/init.vim"
alias nvimplugins="vim ~/dotfiles/nvim/plugins.vim"
alias tmuxconfig="nvim ~/.tmux.conf"
alias ssource='source ~/.zshrc'
#########################################
# Shorten common commands               #
#########################################
alias ex="chmod +x"
alias cat="bat"
alias bc="bc -l"
alias q="~/ && clear"
alias top="htop"
alias emacs="~/Applications/Emacs.app/Contents/MacOS/Emacs"
alias v="nvim"
alias vi="nvim"
alias vim="nvim"
alias lvim="vim -c \"normal '0\""
alias mkdir="mkdir -p"
alias hosts="sudo vi /private/etc/hosts"
alias h="history"
alias hs="history | grep"
alias t="touch"
alias c="clear"
alias ll="ls -lh"
alias l.='ls -d .* --color=auto'
alias lal="ls -lAh"
alias gcc="gcc -Wall -Wextra -Werror"
alias norminette="/usr/bin/norminette"
alias norm="norminette"
alias ct="column -t"
alias grep="grep --color=always"
alias mc="ranger"
alias neofetch="neofetch --ascii ~/.config/neofetch/picture"
alias neo=neofetch
bindkey -s 'qq' ~/./lockscreen^M

#########################################
# WEBSITES                              #
#########################################
alias vk="open https://www.vk.com"
alias telegram="open https://web.telegram.org/"
alias repl="open https://repl.it"

#########################################
# IP / Speedtest                        #
#########################################
alias speedtest='curl -s https://raw.githubusercontent.com/sivel/speedtest-cli/master/speedtest.py | python -'
alias myip='curl ipinfo.io/ip'

#########################################
# GIT                                   #
#########################################
alias gs="git status"
alias gcm="git commit"
alias gignore="vim .gitignore"
alias ga="git add "
alias gl="git log --pretty=format:'%C(Yellow)%h%Creset %ad | %s%d [%C(Green)%an%Creset]' --graph --date=short"
alias gb="git branch"
alias gbnm="git branch --no-merged"
alias go="git checkout"

#########################################
# MY OWN COMMANDS                       #
#########################################
alias now='date +"%T | %d-%m-%Y"'
alias stfu="osascript -e 'set volume output muted true'"

