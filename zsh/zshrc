export EDITOR=vim
export LANG=en_US.UTF-8
export DISPLAY=':0.0'
# export CFLAGS=-DNO_TRUE_COLOURS=1 # Execute this line _only_ if your terminal doesn't support true colours
export CC=clang CXX=clang++
ZSH=$HOME/dotfiles/oh-my-zsh
ZSH_THEME=""
ZSH_CUSTOM=$HOME/dotfiles/zsh/zsh-custom
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern cursor)
ZSH_HIGHLIGHT_PATTERNS=('rm -rf *' 'fg=white,bold,bg=red')

plugins=(
	zsh-autosuggestions
	zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# AUTO CD
setopt auto_cd

#TYPO CORRECTION
unsetopt correct_all

#SOURCING
for file in $HOME/dotfiles/zsh/sourced/*; do
	source "$file"
done

bindkey -v
bindkey -M viins 'jj' vi-cmd-mode
function zle-line-init zle-keymap-select {
    RPS2=$RPS1
    zle reset-prompt
}
bindkey "^?" backward-delete-char

zle -N zle-line-init
zle -N zle-keymap-select

#HISTORY
HISTFILE=~/.zsh_history
SAVEHIST=1000
setopt inc_append_history
setopt share_history

# Load Homebrew config script
source $HOME/.brewconfig.zsh

eval $(thefuck --alias)
if [ -t 0 ] && [[ -z $TMUX ]] && [[ $- = *i* ]]; then exec tmux; fi
neofetch --ascii ~/.config/neofetch/picture
fpath+=('/Volumes/Storage/cache/dmorgil/Library/.brew/lib/node_modules/pure-prompt/functions')

#PURE THEME
autoload -U promptinit; promptinit
prompt pure
